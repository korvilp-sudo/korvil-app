{
  "name": "korvil-banc",
  "version": "1.0.0",
  "description": "KORVIL BANC - Banco digital interno que centraliza todos os recebimentos e pagamentos do KORVIL (estilo Asaas).",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/queue/repasse.worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
